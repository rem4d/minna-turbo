{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		/** Emit types for internal packages to speed up editor performance. */
		"declaration": true,
		"declarationMap": true,
		"noEmit": true,
		"outDir": "${configDir}/dist"
	},
  "exclude": ["node_modules", "dist"],
}
