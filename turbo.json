{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "dependsOn": ["^build"],
      "outputs": [".cache/tsbuildinfo.json", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "batch": {
      "persistent": true,
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "format": {
      "outputs": [".cache/.prettiercache"],
      "outputLogs": "new-only"
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": [".cache/.eslintcache"]
    },
    "check-types": {
      "dependsOn": ["^build", "^check-types"]
    },
    "deploy": {
      "dependsOn": ["^build"],
      "cache": false
    }
  },
  "globalEnv": [
    "SUPABASE_ANON_KEY",
    "SUPABASE_URL",
    "OPENAI_API_KEY",
    "PORT",
    "HOST"
  ],
  "globalPassThroughEnv": ["NODE_ENV"]
}
