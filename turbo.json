{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "tasks": {
    "build": {
      "outputs": ["dist/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "clean": {
      "cache": false
    }
  },
  "globalEnv": [
    "SUPABASE_ANON_KEY",
    "SUPABASE_URL",
    "OPENAI_API_KEY",
    "PORT",
    "HOST"
  ],
  "globalPassThroughEnv": ["NODE_ENV"]
}
