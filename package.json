{
  "name": "minna-turbo",
  "version": "0.0.0",
  "devDependencies": {
    "turbo": "^2.5.6",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.14.0",
  "private": true,
  "scripts": {
    "build": "tsc -b && vite build",
    "clean": "git clean -xdfe .env",
    "dev": "vite",
    "lint": "eslint .",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "preview": "vite preview"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ]
}
